# ──────────────────────────────────────────────────────────
# Shobdokosh News — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ──────────────────────────────────────────────────────────

# ── Supabase (client-side, safe to expose) ────────────────
# Get from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase (server-side, Netlify Functions only) ────────
# NEVER expose these to the browser
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Groq AI (free at console.groq.com) ───────────────────
# Used by Netlify Functions for news summarization & tutor
GROQ_API_KEY=gsk_your-groq-api-key-here

# ── Site URL (for SEO canonical links) ───────────────────
VITE_SITE_URL=https://shobdokosh-news.netlify.app
